# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES
# Copy this file to .env and fill in every value before starting the app.
# Never commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Auth (better-auth) ───────────────────────────────────────────────────────

# Random secret used to sign and verify session tokens.
# Generate a strong value with:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# The canonical public URL of this application (no trailing slash).
# Local dev  →  http://localhost:3000
# Production →  https://your-domain.com
BETTER_AUTH_URL=http://localhost:3000


# ─── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Providers: Supabase, Railway, Neon, self-hosted, etc.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE


# ─── Google OAuth ─────────────────────────────────────────────────────────────
#
# How to obtain these credentials:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create a project (or select an existing one).
#   3. Click "Create Credentials" → "OAuth 2.0 Client ID".
#   4. Set Application type to "Web application".
#   5. Under "Authorized redirect URIs" add:
#        {BETTER_AUTH_URL}/api/auth/callback/google
#      e.g. http://localhost:3000/api/auth/callback/google  (local)
#           https://your-domain.com/api/auth/callback/google (production)
#   6. Copy the Client ID and Client Secret below.
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─── Admin access ─────────────────────────────────────────────────────────────
#
# Comma-separated list of Google-authenticated email addresses that may access
# the admin panel at /admin.  All other users receive a 404.
#
# This variable is read only on the server — it is never sent to the browser.
# The session is also validated against the database before the email is
# checked, so a tampered session cookie cannot bypass this guard.
#
# Example:
#   ADMIN_EMAILS=alice@example.com, bob@example.com
#
ADMIN_EMAILS=
